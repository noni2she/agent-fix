# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# IDE files
.vscode/

# AI tooling files
.github/

# Environment variables
.env

# Playwright auth state（含 session token，絕對不能進 repo）
.playwright-auth.json
*.playwright-auth.json

# Test fixtures（媒體素材不進 repo，.gitkeep 除外）
tests/fixtures/*
!tests/fixtures/.gitkeep

# Runtime project data (not committed)
projects/*/issues/
projects/*/reports/
projects/*/screenshots/
