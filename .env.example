# ==========================================
# SDK Adapter 選擇
# ==========================================

# 選擇要使用的 AI SDK（預設: copilot）
# 可選值: copilot | claude | openai
SDK_ADAPTER=copilot

# 覆寫預設模型（選填）
# copilot 預設: claude-sonnet-4.5
# claude  預設: claude-opus-4-5
# openai  預設: gpt-4o
# DEFAULT_MODEL=claude-opus-4-5

# ==========================================
# GitHub Copilot SDK（SDK_ADAPTER=copilot）
# ==========================================
# 不需要 API key，使用 gh CLI 認證：
#   brew install gh
#   gh extension install github/gh-copilot
#   gh auth login

# ==========================================
# Anthropic Claude SDK（SDK_ADAPTER=claude）
# ==========================================
# ANTHROPIC_API_KEY=sk-ant-...

# ==========================================
# OpenAI Agents SDK（SDK_ADAPTER=openai）
# ==========================================
# OPENAI_API_KEY=sk-...

# ==========================================
# 必填：專案配置
# ==========================================

# 指向 config.yaml（必填）
PROJECT_CONFIG=./config/my-project.yaml

# ==========================================
# Jira Issue Source（issue_source.type: jira）
# ==========================================

# Jira Cloud
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_USER_EMAIL=your@email.com                    # email
# JIRA_API_TOKEN=...                                # https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_AUTH_MODE=basic                              # 預設，Cloud 使用 Basic Auth

# Jira Server（自建）
# JIRA_BASE_URL=https://jira.your-company.com
# JIRA_USER_EMAIL=your_username                     # LDAP username（非 email）
# JIRA_API_TOKEN=your_ldap_password                 # LDAP/AD 登入密碼（Server 不支援 API Token）
# JIRA_AUTH_MODE=session                            # Server 使用 Session Auth
# JIRA_SSL_VERIFY=false                             # 自簽憑證時設為 false

# ==========================================
# Google Sheets Issue Source（issue_source.type: google_sheets）
# ==========================================
# 擇一設定：
# GOOGLE_CREDENTIALS_FILE=./service_account.json  # service account（推薦）
# GOOGLE_API_KEY=AIza...                           # API key（公開試算表）

# ==========================================
# 可選
# ==========================================
# DEBUG=false
