# 環境變數配置範例
# 複製此檔案為 .env 並填入您的配置

# ============================================
# 必填：專案配置檔案
# ============================================
# 指定您的專案 YAML 配置檔案路徑
PROJECT_CONFIG=./examples/morse-webapp.yaml

# ============================================
# 可選：Playwright 配置
# ============================================
# 是否使用無頭模式（預設：true）
PLAYWRIGHT_HEADLESS=true

# 開發伺服器 port（如果配置檔案未指定）
DEV_SERVER_PORT=3001

# ============================================
# 可選：除錯模式
# ============================================
# 啟用詳細日誌（預設：false）
DEBUG=false
